# Copy this to recipes/claude/docker/.env and fill in values.
# .env is git-ignored — never commit secrets.

# Required: AWS Bedrock bearer token for Claude Code authentication.
# Obtain from your AWS session or credential helper.
AWS_BEARER_TOKEN_BEDROCK=

# Set by bin/claude-worktree automatically. Override here only for manual docker compose runs.
# WORKTREE_PATH=/path/to/repo/.worktrees/branch-name
