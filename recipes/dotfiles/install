#!/usr/bin/env bash
set -e

source 'bin/lib/tools'

dir=$PWD

# oh-my-zsh must exist before we symlink .oh-my-zsh/; install it if absent
omz_target="${TARGET_HOME:-$HOME}/.oh-my-zsh"
if [[ ! -d "$omz_target" ]] || [[ -z "$(ls -A "$omz_target" 2>/dev/null)" ]]; then
  echo "oh-my-zsh not found, installing as prerequisite..."
  source "$dir/recipes/oh-my-zsh/install"
fi

# Symlink dotfiles
dotfiles="$(ls -Ap source | grep -v deprecated)"

for dotfile in $dotfiles; do
  dotfile="${dotfile%/}"
  source_path="$dir/source/$dotfile"
  target_path="${TARGET_HOME:-$HOME}/$dotfile"

  [ -e $source_path ] || continue

  # oh-my-zsh is a runtime installation managed by the oh-my-zsh recipe, not a dotfile to symlink
  [[ "$dotfile" == ".oh-my-zsh" ]] && continue

  # Special handling for SSH directory
  if [[ "$dotfile" == ".ssh" ]]; then
    # Create SSH directory with correct permissions only if it doesn't exist
    if [[ ! -d "$target_path" ]]; then
      mkdir -p "$target_path"
      chmod 700 "$target_path"
    fi
    
    # Only symlink config file, skip if private keys exist
    if [[ ! -f "$target_path/config" ]] || [[ -L "$target_path/config" ]]; then
      set_link "$source_path/config" "$target_path/config"
    else
      echo "SSH config already exists, skipping to preserve existing setup"
    fi
  else
    set_link $source_path $target_path
  fi
done
