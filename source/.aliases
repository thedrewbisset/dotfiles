# bash
alias ll='ls -l'
alias la='ls -a'
alias lla='ls -la'

# git
# These commands are forceful and employ a syntax that .gitconfig[alias] does not support.
# Setting them here as they don't need to play nicely with git autocomplete.
# All other git aliases are defined in the .gitconfig
alias g!='git init'
alias gco!='git checkout -b'
alias gal='git add --all'
alias gap!='git add --intent-to-add . && git add --patch'
alias gcln!='git clean --force'
alias gstd!='git stash clear'
alias gca!='git commit --amend -CHEAD'
alias gm!='git merge --no-ff'
alias grst!='git reset --hard'

# colima
alias cl-start='colima start'
alias cl-stop='colima stop'
alias cl-status='colima status'
alias cl-restart='colima stop && colima start'
alias cl-reset='colima delete && colima start'

# docker cleanup
alias docker-cleanup='docker system prune -af --volumes'
alias docker-size='docker system df'

# tmux
alias tmn='tmux new -s'
alias tml='tmux ls'
alias tma='tmux attach -t'

# claude code
alias claude='claude'
alias claude-bedrock='CLAUDE_CODE_USE_BEDROCK=1 claude'
