*.swp
!source/.bats/.keep
source/.bats/*
source/.vim/pack/core/start
!source/.vim/pack/core/start/.keep
source/.vim/pack/core/opt
!source/.vim/pack/core/opt/.keep
source/.vim/undo
!source/.vim/undo/.keep

# Docker secrets
recipes/claude/docker/.env
recipes/claude/docker/.env.local

# Git worktrees created by claude-worktree
**/.worktrees/

# --- Claude Code config (source/.claude) ---
# ~/.claude is Claude Code's live home (a real directory); only the curated
# config below is symlinked in from here, so runtime state never lands in the
# repo. Ignore the whole directory and allowlist just what we version.
# Plugins/marketplaces are reproduced from settings.json (enabledPlugins +
# extraKnownMarketplaces); the plugins/ state files are regenerated by Claude.
source/.claude/*
!source/.claude/CLAUDE.md
!source/.claude/settings.json
!source/.claude/statusline-command.sh
!source/.claude/skills/
